// Indian states and major cities
export const INDIA_LOCATIONS = [
  { state: "Andhra Pradesh", cities: ["Hyderabad", "Vijayawada", "Visakhapatnam"] },
  { state: "Bengaluru", cities: ["Bangalore", "Whitefield", "Koramangala"] },
  { state: "Delhi", cities: ["Delhi", "Noida", "Gurgaon", "Faridabad"] },
  { state: "Gujarat", cities: ["Ahmedabad", "Surat", "Vadodara"] },
  { state: "Haryana", cities: ["Gurgaon", "Noida", "Faridabad"] },
  { state: "Karnataka", cities: ["Bangalore", "Mysore", "Mangalore"] },
  { state: "Kerala", cities: ["Kochi", "Thiruvananthapuram", "Kozhikode"] },
  { state: "Maharashtra", cities: ["Mumbai", "Pune", "Nagpur", "Nashik"] },
  { state: "Telangana", cities: ["Hyderabad", "Warangal", "Nizamabad"] },
  { state: "Tamil Nadu", cities: ["Chennai", "Bangalore", "Coimbatore"] },
  { state: "Uttar Pradesh", cities: ["Noida", "Lucknow", "Kanpur"] },
  { state: "West Bengal", cities: ["Kolkata", "Darjeeling"] },
];

export const IndiaJobsService = {
  /**
   * Search jobs across India
   * @param {Object} params - Search parameters
   * @returns {Promise} Job results
   */
  async searchJobs(params = {}) {
    try {
      const { query = "", location = "", jobType = "" } = params;

      // Filter jobs based on parameters
      let results = INDIA_JOBS;

      // Filter by job title
      if (query) {
        results = results.filter(job =>
          job.title.toLowerCase().includes(query.toLowerCase()) ||
          job.company.toLowerCase().includes(query.toLowerCase()) ||
          job.skills.some(skill => skill.toLowerCase().includes(query.toLowerCase()))
        );
      }

      // Filter by location
      if (location) {
        results = results.filter(job =>
          job.location.toLowerCase().includes(location.toLowerCase()) ||
          job.state.toLowerCase().includes(location.toLowerCase())
        );
      }

      // Filter by job type
      if (jobType && jobType !== "All") {
        results = results.filter(job => job.jobType === jobType);
      }

      // Sort by recently posted
      results.sort((a, b) => new Date(b.posted) - new Date(a.posted));

      return {
        success: true,
        data: results,
        total: results.length,
      };
    } catch (error) {
      console.error("[IndiaJobsService] Search error:", error);
      return {
        success: false,
        message: error.message,
        data: [],
      };
    }
  },

  /**
   * Get all locations in India
   * @returns {Array} Locations array
   */
  getLocations() {
    return INDIA_LOCATIONS;
  },

  /**
   * Get all unique cities
   * @returns {Array} Cities array
   */
  getCities() {
    const cities = new Set();
    INDIA_JOBS.forEach(job => {
      cities.add(job.location);
    });
    return Array.from(cities).sort();
  },

  /**
   * Get all unique job types
   * @returns {Array} Job types
   */
  getJobTypes() {
    const types = new Set();
    INDIA_JOBS.forEach(job => {
      types.add(job.jobType);
    });
    return Array.from(types).sort();
  },

  /**
   * Get all industries
   * @returns {Array} Industries
   */
  getIndustries() {
    const industries = new Set();
    INDIA_JOBS.forEach(job => {
      industries.add(job.industry);
    });
    return Array.from(industries).sort();
  },

  /**
   * Get jobs by salary range
   * @param {number} min - Minimum salary
   * @param {number} max - Maximum salary
   * @returns {Array} Jobs in range
   */
  getJobsBySalary(min, max) {
    return INDIA_JOBS.filter(
      job => job.salaryMin >= min && job.salaryMax <= max
    );
  },

  /**
   * Get jobs by skill match
   * @param {Array} skills - User skills
   * @returns {Array} Matching jobs sorted by match score
   */
  getJobsBySkills(userSkills = []) {
    return INDIA_JOBS.map(job => {
      // Calculate match score based on skills
      const matchedSkills = job.skills.filter(skill =>
        userSkills.some(us => 
          us.toLowerCase().includes(skill.toLowerCase()) ||
          skill.toLowerCase().includes(us.toLowerCase())
        )
      );

      const matchScore = userSkills.length > 0 
        ? (matchedSkills.length / job.skills.length) * 100
        : 0;

      return {
        ...job,
        matchedSkills,
        matchScore: Math.round(matchScore),
      };
    }).filter(job => job.matchScore > 0)
      .sort((a, b) => b.matchScore - a.matchScore);
  },

  /**
   * Get trending jobs (most common titles)
   * @returns {Array} Top jobs
   */
  getTrendingJobs() {
    const jobTitles = {};
    INDIA_JOBS.forEach(job => {
      jobTitles[job.title] = (jobTitles[job.title] || 0) + 1;
    });

    return Object.keys(jobTitles)
      .sort((a, b) => jobTitles[b] - jobTitles[a])
      .slice(0, 10);
  },

  /**
   * Get salary statistics by job title
   * @param {string} jobTitle - Job title
   * @returns {Object} Salary stats
   */
  getSalaryStats(jobTitle) {
    const jobs = INDIA_JOBS.filter(j =>
      j.title.toLowerCase().includes(jobTitle.toLowerCase())
    );

    if (jobs.length === 0) return null;

    const salaries = jobs.map(j => j.salaryMin);
    const avgSalary = salaries.reduce((a, b) => a + b, 0) / salaries.length;

    return {
      minimum: Math.min(...salaries),
      maximum: Math.max(...salaries),
      average: Math.round(avgSalary),
      count: jobs.length,
    };
  },
};
